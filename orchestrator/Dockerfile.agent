FROM node:22-alpine

ARG SERVICE_NAME=agent
ENV SERVICE_NAME=${SERVICE_NAME}

WORKDIR /app

# Install system dependencies
RUN apk add --no-cache curl git bash

COPY orchestrator/package.json orchestrator/package-lock.json* ./
RUN npm install --production

COPY orchestrator/src/agents/ ./src/agents/
COPY orchestrator/src/shared/ ./src/shared/
COPY orchestrator/prompts/ ./prompts/
COPY orchestrator/src/agent-server.js ./src/

EXPOSE 4001 4002 4003 4004

HEALTHCHECK --interval=10s --timeout=5s --retries=3 \
  CMD curl -f http://localhost:${SERVICE_PORT}/health || exit 1

CMD ["node", "src/agent-server.js"]
