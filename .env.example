# QuietWealth Development Plane Control – Environment Variables
# Copy this file to .env and fill in your values:
#   cp .env.example .env

# ── Required ──────────────────────────────────────────────────
# Your Anthropic API key (powers all AI agents)
ANTHROPIC_API_KEY=sk-ant-...

# ── Optional ──────────────────────────────────────────────────
# GitHub Personal Access Token with repo scope (enables real PR creation)
# Without this, /release-feature will simulate the PR URL
GITHUB_TOKEN=ghp_...

# GitHub repository in "owner/repo" format
GITHUB_REPOSITORY=your-org/quietwealth

# ── Infrastructure (auto-configured via Docker Compose) ───────
# These are set automatically – only override for local dev outside Docker
# SQL_CONNECTION_STRING=Server=localhost,14333;Database=QuietWealthTestDb;...
# REDIS_CONNECTION_STRING=localhost:6380
# AZURITE_CONNECTION_STRING=DefaultEndpointsProtocol=http;...
